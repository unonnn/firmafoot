# Copie para ".env" na raiz do projeto (nunca comite o .env de verdade).
# Usado pelo docker-compose.yml para substituição de variáveis do serviço "web".

# Gere com: openssl rand -base64 32
AUTH_SECRET=

# URL pública onde o app vai ficar acessível (ajuste em produção).
NEXTAUTH_URL=http://localhost:3000
